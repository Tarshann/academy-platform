# ============================================================================
# Academy Platform - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# DO NOT commit .env to version control.

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/academy_platform

# ============================================================================
# Authentication (Clerk) & OAuth
# ============================================================================
CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional server-side fallback if your platform cannot inject Vite env vars
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_ADMIN_EMAIL=admin@example.com
VITE_APP_ID=your_app_id_here
VITE_OAUTH_PORTAL_URL=https://oauth.example.com
OAUTH_SERVER_URL=https://oauth-api.example.com
JWT_SECRET=your_jwt_secret_key_here
OWNER_OPEN_ID=your_owner_open_id_here

# ============================================================================
# Stripe Payment Integration
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Email Service (Resend)
# ============================================================================
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ============================================================================
# Forge API (File Storage & Proxy Services)
# ============================================================================
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
BUILT_IN_FORGE_API_URL=https://forge.manus.ai
BUILT_IN_FORGE_API_KEY=your_backend_forge_api_key

# ============================================================================
# Real-Time Messaging (Ably)
# ============================================================================
# Get this from: https://ably.com/accounts — required for real-time chat
ABLY_API_KEY=your_ably_api_key_here

# ============================================================================
# Web Push Notifications (VAPID)
# ============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ============================================================================
# File Upload Constraints
# ============================================================================
# Max upload size in bytes (0 = unlimited)
STORAGE_MAX_BYTES=10485760
# Comma-separated MIME types (leave empty to allow all — not recommended)
STORAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================================================
# Analytics (Optional)
# ============================================================================
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================================================
# SEO / Public URL
# ============================================================================
VITE_SITE_URL=https://academy-platform-one.vercel.app
# Server-side fallback for VITE_SITE_URL (used in checkout origin detection)
SITE_URL=https://academy-platform-one.vercel.app

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=development
# Set to "false" to disable Socket.IO (recommended for serverless deploys)
ENABLE_SOCKET_IO=true

# ============================================================================
# E2E Testing (Optional)
# ============================================================================
# Base URL for Playwright portal tests (defaults to http://localhost:5173)
E2E_BASE_URL=http://localhost:5173
