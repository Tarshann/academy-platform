{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/chat/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/capture/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/upload",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/profile/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/health",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/skills-lab-register",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/performance-lab-apply",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/stripe/:path*",
      "destination": "/api/stripe/webhook"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://analytics.academytn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://api.clerk.com https://*.clerk.accounts.dev https://api.stripe.com wss://*.ably.io https://analytics.academytn.com; frame-src https://checkout.stripe.com https://js.stripe.com; object-src 'none'; base-uri 'self'" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "X-Permitted-Cross-Domain-Policies", "value": "none" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://app.academytn.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    { "path": "/api/cron/nurture", "schedule": "0 14 * * *" },
    { "path": "/api/cron/generate-sessions", "schedule": "0 3 * * 0" },
    { "path": "/api/cron/session-reminders", "schedule": "0 13 * * *" },
    { "path": "/api/cron/merch-drops", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/metrics-prompt", "schedule": "0 1 * * 2,4,0" },
    { "path": "/api/cron/progress-reports", "schedule": "0 23 * * 5" },
    { "path": "/api/cron/reengagement", "schedule": "0 15 * * 1" },
    { "path": "/api/cron/parent-digest", "schedule": "0 18 * * 5" },
    { "path": "/api/cron/post-session-content", "schedule": "0 1 * * 2,4,0" },
    { "path": "/api/cron/ai-smart-notifications", "schedule": "0 22 * * *" },
    { "path": "/api/cron/ai-gallery-capture", "schedule": "0 3 * * *" },
    { "path": "/api/cron/ai-showcase-generator", "schedule": "0 1 * * 1" },
    { "path": "/api/cron/ai-content-autopublish", "schedule": "0 14 * * *" },
    { "path": "/api/cron/ai-announcement-drafter", "schedule": "0 13 * * *" },
    { "path": "/api/cron/ai-blog-generator", "schedule": "0 15 * * 6" },
    { "path": "/api/cron/ai-feed-engagement", "schedule": "0 12,20 * * *" }
  ]
}
