{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/chat/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/capture/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/upload",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/profile/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/health",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/skills-lab-register",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/performance-lab-apply",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api/stripe/:path*",
      "destination": "/api/stripe/webhook"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://app.academytn.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    { "path": "/api/cron/nurture", "schedule": "0 14 * * *" },
    { "path": "/api/cron/generate-sessions", "schedule": "0 3 * * 0" },
    { "path": "/api/cron/session-reminders", "schedule": "0 13 * * *" },
    { "path": "/api/cron/merch-drops", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/metrics-prompt", "schedule": "0 1 * * 2,4,0" },
    { "path": "/api/cron/progress-reports", "schedule": "0 23 * * 5" },
    { "path": "/api/cron/reengagement", "schedule": "0 15 * * 1" },
    { "path": "/api/cron/parent-digest", "schedule": "0 18 * * 5" },
    { "path": "/api/cron/post-session-content", "schedule": "0 1 * * 2,4,0" },
    { "path": "/api/cron/ai-smart-notifications", "schedule": "0 22 * * *" }
  ]
}
